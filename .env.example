# =============================================
# WORLD CUP FANTASY 2026 — ENVIRONMENT VARS
# Copy to .env.local and fill in values
# =============================================

# Supabase — from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose client-side

# Football Data API — free tier at football-data.org
# Sign up at: https://www.football-data.org/client/register
# 2026 World Cup competition code: WC
FOOTBALL_DATA_API_KEY=your-api-key

# Resend (email notifications) — https://resend.com
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Cron secret — set a random string, pass as header in Vercel cron
CRON_SECRET=your-random-secret-string

# App URL — used for email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
