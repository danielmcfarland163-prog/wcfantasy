# =============================================
# SOCCER FANTASY GAME — ENVIRONMENT VARS
# Copy to .env.local and fill in values
# =============================================

# Supabase — from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose client-side

# Football Data API — free tier at football-data.org
# Sign up at: https://www.football-data.org/client/register
# Competition code (football-data.org): WC
FOOTBALL_DATA_API_KEY=your-api-key

# Resend (email notifications) — https://resend.com
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Cron secret — set a random string, pass as header in Vercel cron
CRON_SECRET=your-random-secret-string

# App URL — used for email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bracket lock time (ISO 8601, UTC) — when brackets freeze (first match kickoff).
# Optional; defaults to 2026-06-11T15:00:00Z. NEXT_PUBLIC_ so server + client agree.
NEXT_PUBLIC_BRACKET_LOCK=2026-06-11T15:00:00Z
